<?xml version="1.0" encoding="utf-8"?>
<!-- TapSulor 暗色更新弹窗背景：深色卡片 + 青色细描边 + 顶部一条青色强调线 -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 主卡片：深灰底 + 青色描边 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1E1F23" />
            <stroke
                android:width="1dp"
                android:color="#2A6B72" />
            <corners android:radius="12dp" />
        </shape>
    </item>

    <!-- 顶部青色高亮条（盖在主卡片之上，仅顶部 3dp 高度的胶囊条） -->
    <item
        android:top="12dp"
        android:bottom="@null"
        android:left="24dp"
        android:right="24dp">
        <shape android:shape="rectangle">
            <solid android:color="#00C4CD" />
            <corners android:radius="2dp" />
            <size android:height="3dp" />
        </shape>
    </item>

</layer-list>
