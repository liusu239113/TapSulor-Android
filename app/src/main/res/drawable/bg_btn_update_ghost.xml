<?xml version="1.0" encoding="utf-8"?>
<!-- 次按钮：深灰底 + 浅描边，圆角 8dp，按下变亮一点 -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#36383E" />
            <stroke
                android:width="1dp"
                android:color="#3A4A4D" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#2A2B30" />
            <stroke
                android:width="1dp"
                android:color="#2C2D31" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</selector>
