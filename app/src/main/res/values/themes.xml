<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.TapTapGain" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">#00C4CD</item>
        <item name="colorPrimaryVariant">#00A8B0</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#00C4CD</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <!-- 沉浸式全屏：状态栏与导航栏透明，由 Kotlin 侧 WindowInsetsController 隐藏系统栏 -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

    <!-- 更新弹窗：无 ActionBar、无标题、透明窗口背景（形状由自定义 layout 的 drawable 控制） -->
    <style name="Theme.TapTapGain.UpdateDialog" parent="Theme.AppCompat.Dialog">
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:windowAnimationStyle">@style/Animation.AppCompat.Dialog</item>
    </style>
</resources>
